&share
 wrf_core             = 'ARW'
 max_dom              = 1,
 start_date           = '2025-08-13_12:00:00',
 end_date             = '2025-08-14_12:00:00',
 interval_seconds     = 10800,
 io_form_geogrid      = 2,
/

&geogrid
 parent_id            = 1,
 parent_grid_ratio    = 1,
 i_parent_start       = 1,
 j_parent_start       = 1,
 e_we                 = 30,
 e_sn                 = 30,
 geog_data_res        = 'gtopo_30s+usgs_30s+30s+ncep+default+default',
 dx                   = 25000,
 dy                   = 25000,
 map_proj             = 'lambert',
 ref_lat   = 51.70,
 ref_lon   = -2.10,
 truelat1  = 50.00,
 truelat2  = 58.00,
 stand_lon = -2.10,
 geog_data_path       = '/root/rasp/geog'
 opt_geogrid_tbl_path = '.'
/

&ungrib
 out_format           = 'WPS',
 prefix               = 'UNGRIB',
/

&metgrid
 opt_metgrid_tbl_path = '.'
 fg_name              = 'UNGRIB',
 io_form_metgrid      = 2,
/

