# API Keys Configuration
# Copy this file to .env and fill in your actual keys

# Mapbox Configuration
# Get your access token from https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Weather Stations API (Windy Stations)
WEATHER_STATIONS_API_KEY=your_weather_stations_api_key_here

# Webcams API (Windy Webcams)
WEBCAMS_API_KEY=your_webcams_api_key_here
